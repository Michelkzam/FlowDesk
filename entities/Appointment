{
  "name": "Appointment",
  "type": "object",
  "properties": {
    "title": {
      "type": "string",
      "description": "T\u00edtulo do agendamento"
    },
    "description": {
      "type": "string",
      "description": "Descri\u00e7\u00e3o / Observa\u00e7\u00f5es"
    },
    "date": {
      "type": "string",
      "format": "date",
      "description": "Data do agendamento (YYYY-MM-DD)"
    },
    "time": {
      "type": "string",
      "description": "Hor\u00e1rio (HH:mm)"
    },
    "type": {
      "type": "string",
      "enum": [
        "meeting",
        "call",
        "task",
        "other"
      ],
      "default": "meeting",
      "description": "Tipo"
    },
    "responsible": {
      "type": "string",
      "description": "Respons\u00e1vel"
    },
    "client_id": {
      "type": "string",
      "description": "ID do cliente (opcional)"
    },
    "client_name": {
      "type": "string",
      "description": "Nome do cliente"
    },
    "ticket_id": {
      "type": "string",
      "description": "Ticket relacionado"
    },
    "status": {
      "type": "string",
      "enum": [
        "scheduled",
        "completed",
        "cancelled"
      ],
      "default": "scheduled"
    }
  },
  "required": [
    "title",
    "date"
  ]
}