{
  "name": "Department",
  "type": "object",
  "properties": {
    "name": {
      "type": "string",
      "description": "Nome do departamento"
    },
    "manager_id": {
      "type": "string",
      "description": "ID do gerente"
    },
    "manager_name": {
      "type": "string",
      "description": "Nome do gerente"
    },
    "email_id": {
      "type": "string",
      "description": "Email associado"
    },
    "sla_id": {
      "type": "string",
      "description": "ID do SLA padr\u00e3o"
    },
    "schedule_id": {
      "type": "string",
      "description": "ID do hor\u00e1rio"
    },
    "auto_response_new_ticket": {
      "type": "boolean",
      "default": false
    },
    "auto_response_new_message": {
      "type": "boolean",
      "default": false
    },
    "alert_recipients": {
      "type": "string",
      "enum": [
        "all_members",
        "primary_only",
        "admin_email",
        "none"
      ],
      "default": "all_members"
    },
    "signature": {
      "type": "string",
      "description": "Assinatura do departamento"
    },
    "type": {
      "type": "string",
      "enum": [
        "public",
        "private"
      ],
      "default": "public"
    },
    "status": {
      "type": "string",
      "enum": [
        "active",
        "inactive"
      ],
      "default": "active"
    },
    "notes": {
      "type": "string"
    }
  },
  "required": [
    "name"
  ]
}