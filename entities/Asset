    },
    "client_name": {
      "type": "string",
      "description": "Cliente vinculado"
    },
    "client_id": {
      "type": "string",
      "description": "ID do cliente"
    },
    "location": {
      "type": "string",
      "description": "Localiza\u00e7\u00e3o f\u00edsica"
    },
    "purchase_date": {
      "type": "string",
      "format": "date"
    },
    "warranty_date": {
      "type": "string",
      "format": "date",
