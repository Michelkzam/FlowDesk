{
  "name": "Ticket",
  "type": "object",
  "properties": {
    "number": {
      "type": "string",
      "description": "N\u00famero do chamado"
    },
    "title": {
      "type": "string",
      "description": "Assunto do chamado"
    },
    "description": {
      "type": "string",
      "description": "Descri\u00e7\u00e3o do chamado"
    },
    "status": {
      "type": "string",
      "enum": [
        "open",
        "in_progress",
        "waiting",
        "pending_approval",
        "resolved",
        "closed"
      ],
      "default": "open"
    },
    "priority": {
      "type": "string",
      "enum": [
        "low",
        "normal",
        "high",
        "emergency"
      ],
      "default": "normal"
    },
    "department_id": {
      "type": "string",
      "description": "ID do departamento"
    },
    "department_name": {
      "type": "string",
      "description": "Nome do departamento"
    },
    "agent_id": {
      "type": "string",
      "description": "ID do agente respons\u00e1vel"
    },
    "agent_name": {
      "type": "string",
      "description": "Nome do agente"
    },
    "team_id": {
      "type": "string",
      "description": "ID da equipe"
    },
    "team_name": {
      "type": "string",
      "description": "Nome da equipe"
    },
    "user_id": {
      "type": "string",
      "description": "ID do usu\u00e1rio/cliente"
    },
    "user_name": {
      "type": "string",
      "description": "Nome do usu\u00e1rio"
    },
    "user_email": {
      "type": "string",
      "description": "Email do usu\u00e1rio"
    },
    "user_phone": {
      "type": "string",
      "description": "Telefone do usu\u00e1rio"
    },
    "organization_id": {
      "type": "string",
      "description": "ID da organiza\u00e7\u00e3o"
    },
    "organization_name": {
      "type": "string",
      "description": "Nome da organiza\u00e7\u00e3o"
    },
    "help_topic_id": {
      "type": "string",
      "description": "ID do t\u00f3pico de ajuda"
    },
    "help_topic_name": {
      "type": "string",
      "description": "Nome do t\u00f3pico de ajuda"
    },
    "sla_id": {
      "type": "string",
      "description": "ID do plano de SLA"
    },
    "sla_name": {
      "type": "string",
      "description": "Nome do SLA"
    },
    "due_date": {
      "type": "string",
      "format": "date-time",
      "description": "Data de vencimento"
    },
    "closed_date": {
      "type": "string",
      "format": "date-time",
      "description": "Data de fechamento"
    },
    "source": {
      "type": "string",
      "enum": [
        "web",
        "email",
        "api",
        "phone",
        "whatsapp"
      ],
      "default": "web",
      "description": "Origem do chamado"
    },
    "is_overdue": {
      "type": "boolean",
      "default": false
    },
    "last_response_date": {
      "type": "string",
      "format": "date-time"
    },
    "last_user_response_date": {
      "type": "string",
      "format": "date-time",
      "description": "Data da última resposta do usuário/cliente"
    },
    "category_id": {
      "type": "string",
      "description": "ID da categoria"
    },
    "category_name": {
      "type": "string",
      "description": "Nome da categoria"
    }
  },
  "required": [
    "title"
  ]
}