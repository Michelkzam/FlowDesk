{
  "name": "ChannelLink",
  "type": "object",
  "properties": {
    "channel": {
      "type": "string",
      "enum": [
        "whatsapp",
        "telegram"
      ],
      "description": "Canal"
    },
    "name": {
      "type": "string",
      "description": "Nome da conex\u00e3o"
    },
    "phone_number": {
      "type": "string",
      "description": "N\u00famero de telefone"
    },
    "status": {
      "type": "string",
      "enum": [
        "connected",
        "disconnected",
        "pending"
      ],
      "default": "disconnected"
    },
    "qr_code": {
      "type": "string",
      "description": "QR Code data"
    },
    "last_connected": {
      "type": "string",
      "format": "date-time",
      "description": "\u00daltima conex\u00e3o"
    }
  },
  "required": [
    "channel",
    "name"
  ]
}