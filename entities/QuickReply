{
  "name": "QuickReply",
  "type": "object",
  "properties": {
    "title": {
      "type": "string",
      "description": "T\u00edtulo da resposta r\u00e1pida"
    },
    "content": {
      "type": "string",
      "description": "Texto da resposta"
    },
    "type": {
      "type": "string",
      "enum": [
        "greeting",
        "closing",
        "info",
        "other"
      ],
      "default": "other",
      "description": "Tipo de resposta"
    },
    "shortcut": {
      "type": "string",
      "description": "Atalho (ex: /ola)"
    },
    "status": {
      "type": "string",
      "enum": [
        "active",
        "inactive"
      ],
