{
  "name": "TicketMessage",
  "type": "object",
  "properties": {
    "ticket_id": {
      "type": "string",
      "description": "ID do ticket"
    },
    "type": {
      "type": "string",
      "enum": [
        "message",
        "reply",
        "note",
        "system"
      ],
      "default": "message",
      "description": "Tipo da mensagem"
    },
    "sender_type": {
      "type": "string",
      "enum": [
        "user",
        "agent",
        "system"
      ],
      "default": "agent"
    },
    "sender_id": {
      "type": "string"
    },
    "sender_name": {
      "type": "string"
    },
    "body": {
      "type": "string",
      "description": "Conte\u00fado da mensagem"
    },
    "is_internal": {
      "type": "boolean",
      "default": false,
      "description": "Nota interna"
    }
  },
  "required": [
    "ticket_id",
    "body"
  ]
}