{
  "name": "TicketFilter",
  "type": "object",
  "properties": {
    "name": {
      "type": "string",
      "description": "Nome do filtro"
    },
    "execution_order": {
      "type": "number",
      "description": "Ordem de execu\u00e7\u00e3o"
    },
    "status": {
      "type": "string",
      "enum": [
        "active",
        "inactive"
      ],
      "default": "active"
    },
    "target": {
      "type": "string",
      "enum": [
        "any",
        "web",
        "api",
        "email",
        "specific_email"
      ],
      "default": "any"
    },
    "match_type": {
      "type": "string",
      "enum": [
        "any",
        "all"
      ],
      "default": "all"
    },
    "rules": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "field": {
            "type": "string"
          },
          "condition": {
            "type": "string"
          },
          "value": {
            "type": "string"
          }
        }
      }
    },
    "actions": {
      "type": "object",
      "properties": {
        "reject": {
          "type": "boolean"
        },
        "disable_auto_response": {
          "type": "boolean"
        },
        "set_department_id": {
          "type": "string"
        },
        "set_status": {
          "type": "string"
        },
        "set_priority": {
          "type": "string"
        },
        "set_sla_id": {
          "type": "string"
        },
        "set_help_topic_id": {
          "type": "string"
        },
        "auto_assign_agent_id": {
          "type": "string"
        },
        "auto_assign_team_id": {
          "type": "string"
        }
      }
    },
    "notes": {
      "type": "string"
    }
  },
  "required": [
    "name"
  ]
}